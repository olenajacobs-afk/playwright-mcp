{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "./playwright.config.ts",
    "../playwright.config.ts",
    "./pw-tests/**/*.ts",
    "../pw-tests/**/*.ts",
    "./tests/**/*.ts",
    "../tests/**/*.ts",
    "./**/*.ts"
  ],
  "exclude": ["node_modules", "playwright-report", "test-results", "dist", "build"]
}
