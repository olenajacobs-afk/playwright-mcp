{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": false,
		"noEmit": true,
		"allowJs": true,
		"checkJs": false,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["playwright.config.ts", "src/**/*.ts", "tests/**/*.ts", "pw-tests/**/*.ts"],
	"exclude": ["node_modules"]
}
